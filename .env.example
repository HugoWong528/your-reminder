# Discord bot token (required for discord_bot.py).
# Create a bot at https://discord.com/developers/applications,
# enable "MESSAGE CONTENT INTENT" under Bot > Privileged Gateway Intents,
# then paste the token below.
DISCORD_BOT_TOKEN=

# Optional: pollinations.ai API key for AI-powered clothing suggestions.
# Leave empty to use the built-in rule-based suggestions instead.
# Get your key at https://enter.pollinations.ai
POLLINATIONS_API_KEY=
